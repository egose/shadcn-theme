{
  "name": "@egose/shadcn-theme",
  "version": "0.0.0-PLACEHOLDER",
  "description": "shadcn UI theme for React",
  "license": "PLACEHOLDER",
  "author": "PLACEHOLDER",
  "sideEffects": false,
  "private": true,
  "homepage": "https://github.com/egose/shadcn-theme",
  "repository": {
    "type": "git",
    "url": "https://github.com/egose/shadcn-theme",
    "directory": "packages/react"
  },
  "bugs": {
    "url": "https://github.com/egose/shadcn-theme/issues"
  },
  "keywords": [
    "shadcn",
    "shadcn-ui",
    "react",
    "tailwindcss",
    "ui",
    "components",
    "design-system"
  ],
  "files": [
    "components",
    "hooks",
    "utils",
    "layouts",
    "lib",
    "*.mjs",
    "*.js",
    "README.md",
    "LICENSE",
    "llms.txt"
  ],
  "exports": {
    "./components/ui/*": {
      "types": "./components/ui/*.d.mts",
      "import": "./components/ui/*.mjs",
      "require": "./components/ui/*.js"
    },
    "./components/form/*": {
      "types": "./components/form/*.d.mts",
      "import": "./components/form/*.mjs",
      "require": "./components/form/*.js"
    },
    "./components/widgets/dialog-manager": {
      "types": "./components/widgets/dialog-manager/index.d.mts",
      "import": "./components/widgets/dialog-manager/index.mjs",
      "require": "./components/widgets/dialog-manager/index.js"
    },
    "./components/widgets/*": {
      "types": "./components/widgets/*.d.mts",
      "import": "./components/widgets/*.mjs",
      "require": "./components/widgets/*.js"
    },
    "./components/widgets/dialog-manager/*": {
      "types": "./components/widgets/dialog-manager/*.d.mts",
      "import": "./components/widgets/dialog-manager/*.mjs",
      "require": "./components/widgets/dialog-manager/*.js"
    },
    "./hooks/*": {
      "types": "./hooks/*.d.mts",
      "import": "./hooks/*.mjs",
      "require": "./hooks/*.js"
    },
    "./utils/*": {
      "types": "./utils/*.d.mts",
      "import": "./utils/*.mjs",
      "require": "./utils/*.js"
    },
    "./layouts/simple": {
      "types": "./layouts/simple/index.d.mts",
      "import": "./layouts/simple/index.mjs",
      "require": "./layouts/simple/index.js"
    },
    "./layouts/simple/*": {
      "types": "./layouts/simple/*.d.mts",
      "import": "./layouts/simple/*.mjs",
      "require": "./layouts/simple/*.js"
    },
    "./layouts/sidebar1": {
      "types": "./layouts/sidebar1/index.d.mts",
      "import": "./layouts/sidebar1/index.mjs",
      "require": "./layouts/sidebar1/index.js"
    },
    "./layouts/sidebar1/*": {
      "types": "./layouts/sidebar1/*.d.mts",
      "import": "./layouts/sidebar1/*.mjs",
      "require": "./layouts/sidebar1/*.js"
    },
    "./package.json": "./package.json"
  },
  "scripts": {
    "dev": "tsc -w",
    "bundle": "tsup",
    "postbundle": "node prepend-use-client.mjs"
  },
  "dependencies": {
    "@base-ui/react": "^1.6.0",
    "@hookform/resolvers": "^5.4.0",
    "@tabler/icons-react": "^3.44.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "cmdk": "1.1.1",
    "date-fns": "^4.4.0",
    "embla-carousel-react": "^8.5.2",
    "input-otp": "^1.4.2",
    "lodash-es": "^4.18.1",
    "lucide-react": "^1.23.0",
    "next-themes": "^0.4.4",
    "radix-ui": "^1.6.1",
    "react-day-picker": "10.0.1",
    "react-resizable-panels": "^4.12.1",
    "tailwind-merge": "^3.6.0",
    "valtio": "^2.3.2",
    "vaul": "^1.1.2",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@types/lodash-es": "^4.17.12",
    "@types/node": "^26.1.0",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "esbuild": "^0.28.1",
    "fast-glob": "^3.3.3",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "react-hook-form": "^7.81.0",
    "tsup": "^8.5.1",
    "typescript": "^6.0.3"
  },
  "peerDependencies": {
    "react": "^18.3.1 || ^19.0.0",
    "react-dom": "^18.3.1 || ^19.0.0",
    "react-hook-form": "^7.54.2",
    "sonner": "^2.0.7"
  },
  "engines": {
    "node": ">=20"
  }
}
